    class FW1,FW2,FW3,EP1,EP2,EP3,EP4,TR1 l2Node
    class OR1,OR2,OR3,PR1 l3Node
    class AG1,AG2,AG3,AG4,AG5,TL1,TL2,TL3,TL4,TL5 agNode
    class CP1,DB1,DB2,FS1,FS2,IP1,IP2 l4Node
    class WS1,DP1,DP2,DP3,ST1,FT1,FT2,FT3 l5Node
