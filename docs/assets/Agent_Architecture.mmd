    class A2_IN,A2_P1,A2_P2,A2_P3,A2_OUT agent2Node
    class A3_IN,A3_P1,A3_P2,A3_P3,A3_OUT agent3Node
    class A4_IN,A4_P1,A4_P2,A4_P3,A4_OUT agent4Node
    class A5_IN,A5_P1,A5_P2,A5_P3,A5_OUT agent5Node
    class T1,T2,T3,T4,T5,T6,T7,T8,T9,T10,T11 toolNode
    class PM1,PM2,PM3,PM4,PM5,PM6,PV1,PV2,PS1,PS2,PR1,PR2,PR3 persistNode
    class LLM1,LLM2,LLM3 llmNode
    class MR1,MR2,MR3 manualNode
