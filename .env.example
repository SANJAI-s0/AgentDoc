# ============================================================================
# AgentDoc Environment Configuration
# 5-Agent System - Production Ready with Security Hardening
# ============================================================================

# ============================================================================
# DJANGO CORE SETTINGS
# ============================================================================

# Secret key for Django (CHANGE IN PRODUCTION!)
# Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=change-me-in-production-use-random-50-char-string

# Debug mode (0 = False, 1 = True)
# CRITICAL: Set to 0 in production for security!
DJANGO_DEBUG=1

# Allowed hosts (comma-separated)
# Local: localhost,127.0.0.1
# Production: your-domain.com,www.your-domain.com,your-backend.onrender.com
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# CORS allowed origins (comma-separated)
# Must include all frontend URLs that will access the API
# Production: https://your-domain.com,https://www.your-domain.com
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:8000

# CSRF trusted origins (comma-separated)
# Must match CORS origins for security
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:8000

# Use X-Forwarded-Host header (1 = True, 0 = False)
# Enable for reverse proxy deployments (Render, AWS, Nginx, etc.)
DJANGO_USE_X_FORWARDED_HOST=1

# Trust X-Forwarded-Proto header (1 = True, 0 = False)
# Enable for HTTPS behind reverse proxy
DJANGO_TRUST_X_FORWARDED_PROTO=1

# Session cookie settings
# Set SECURE to 1 for HTTPS-only cookies in production
DJANGO_SESSION_COOKIE_SECURE=0
DJANGO_SESSION_COOKIE_SAMESITE=Lax
DJANGO_SESSION_COOKIE_HTTPONLY=1

# CSRF cookie settings
# Set SECURE to 1 for HTTPS-only cookies in production
DJANGO_CSRF_COOKIE_SECURE=0
DJANGO_CSRF_COOKIE_SAMESITE=Lax
DJANGO_CSRF_COOKIE_HTTPONLY=1

# Allow all origins (NOT RECOMMENDED FOR PRODUCTION!)
# Only use for development/testing
DJANGO_CORS_ALLOW_ALL_ORIGINS=0

# ============================================================================
# DATABASE - MONGODB
# ============================================================================

# MongoDB connection string
# Local: mongodb://localhost:27017
# Atlas: mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017

# Database name
MONGODB_DB_NAME=agentdoc

# Vector search index name (for semantic search)
MONGODB_VECTOR_INDEX=documents_vector_index

# Enable vector search (1 = True, 0 = False)
MONGODB_ENABLE_VECTOR_SEARCH=1

# Vector embedding dimensions (default: 165)
# Must match sentence-transformers model output
EMBEDDING_VECTOR_DIMENSIONS=165

# ============================================================================
# STORAGE CONFIGURATION
# ============================================================================

# Use local storage instead of MinIO/S3 (1 = True, 0 = False)
# Recommended for Render free tier and simple deployments
USE_LOCAL_STORAGE=1

# Local storage path (when USE_LOCAL_STORAGE=1)
# Relative to backend directory
MEDIA_ROOT=media
MEDIA_URL=/media/

# Maximum upload file size (in MB)
MAX_UPLOAD_SIZE_MB=10

# MinIO/S3 Configuration (when USE_LOCAL_STORAGE=0)
# Only needed if using external object storage
# MINIO_ENDPOINT=localhost:9000
# MINIO_ACCESS_KEY=minioadmin
# MINIO_SECRET_KEY=minioadmin
# MINIO_BUCKET=documents
# MINIO_SECURE=0  # Set to 1 for HTTPS

# ============================================================================
# AI CONFIGURATION - 5-AGENT SYSTEM
# ============================================================================

# Google Gemini API Key (REQUIRED)
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=replace-with-your-gemini-api-key

# Gemini model to use
# Options: gemini/gemini-2.5-flash, gemini/gemini-pro
GEMINI_MODEL=gemini/gemini-2.5-flash

# Agent internal token (for inter-service communication)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
AGENT_INTERNAL_TOKEN=replace-with-random-long-token

# ============================================================================
# JWT AUTHENTICATION
# ============================================================================

# Access token lifetime (in minutes)
JWT_ACCESS_MINUTES=60

# Refresh token lifetime (in days)
JWT_REFRESH_DAYS=7

# ============================================================================
# EMAIL NOTIFICATIONS
# ============================================================================

# Default from email address
DEFAULT_FROM_EMAIL=ops@agentdoc.local

# SMTP server configuration
# Local development: Use MailHog (localhost:1025)
# Production: Use your SMTP provider
SMTP_HOST=localhost
SMTP_PORT=1025

# SMTP authentication (if required)
# SMTP_USER=your-smtp-username
# SMTP_PASSWORD=your-smtp-password
# SMTP_USE_TLS=1

# ============================================================================
# APPLICATION URLS
# ============================================================================

# Backend base URL
# Local: http://localhost:8000
# Production: https://your-backend.onrender.com
BACKEND_URL=http://localhost:8000

# Review portal URL (for email notifications)
# Local: http://localhost:8000/app/reviews
# Production: https://your-backend.onrender.com/app/reviews
REVIEW_PORTAL_URL=http://localhost:8000/app/reviews

