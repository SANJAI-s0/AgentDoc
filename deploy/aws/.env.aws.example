# Django
DJANGO_SECRET_KEY=replace-me
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,<your-domain>,<alb-domain>
DJANGO_CORS_ALLOWED_ORIGINS=https://<your-domain>
DJANGO_CSRF_TRUSTED_ORIGINS=https://<your-domain>
DJANGO_USE_X_FORWARDED_HOST=1
DJANGO_TRUST_X_FORWARDED_PROTO=1
DJANGO_SESSION_COOKIE_SECURE=1
DJANGO_CSRF_COOKIE_SECURE=1

# MongoDB (set to Atlas for production)
MONGODB_URI=mongodb://mongodb:27017
MONGODB_DB_NAME=agentdoc
MONGODB_VECTOR_INDEX=documents_vector_index
MONGODB_ENABLE_VECTOR_SEARCH=1
EMBEDDING_VECTOR_DIMENSIONS=165

# MinIO (or S3-compatible endpoint)
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=documents
MINIO_SECURE=0

# Gemini
GEMINI_API_KEY=replace-me
GEMINI_MODEL=gemini/gemini-2.5-flash

# Auth
JWT_ACCESS_MINUTES=60
JWT_REFRESH_DAYS=7

# Email
DEFAULT_FROM_EMAIL=ops@agentdoc.local
SMTP_HOST=email-smtp.<region>.amazonaws.com
SMTP_PORT=587

# App links
REVIEW_PORTAL_URL=https://<your-domain>/reviews
AGENT_INTERNAL_TOKEN=replace-with-long-random-token

# Gunicorn
GUNICORN_WORKERS=3
GUNICORN_TIMEOUT=120
