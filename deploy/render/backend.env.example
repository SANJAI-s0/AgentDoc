# Backend env example for Render
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=.onrender.com
DJANGO_CORS_ALLOWED_ORIGINS=https://agentdoc-frontend.onrender.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://agentdoc-frontend.onrender.com
DJANGO_USE_X_FORWARDED_HOST=1
DJANGO_TRUST_X_FORWARDED_PROTO=1
DJANGO_SESSION_COOKIE_SECURE=1
DJANGO_CSRF_COOKIE_SECURE=1

MONGODB_URI=mongodb+srv://<user>:<pass>@<cluster>/<db>?retryWrites=true&w=majority
MONGODB_DB_NAME=agentdoc
MONGODB_VECTOR_INDEX=documents_vector_index
MONGODB_ENABLE_VECTOR_SEARCH=1
EMBEDDING_VECTOR_DIMENSIONS=165

MINIO_ENDPOINT=<minio-host>:443
MINIO_ACCESS_KEY=<minio-access-key>
MINIO_SECRET_KEY=<minio-secret-key>
MINIO_BUCKET=documents
MINIO_SECURE=1

GEMINI_API_KEY=<gemini-key>
GEMINI_MODEL=gemini/gemini-2.5-flash

DEFAULT_FROM_EMAIL=ops@agentdoc.local
SMTP_HOST=<smtp-host>
SMTP_PORT=587

REVIEW_PORTAL_URL=https://agentdoc-frontend.onrender.com/reviews
AGENT_INTERNAL_TOKEN=<long-random-token>
