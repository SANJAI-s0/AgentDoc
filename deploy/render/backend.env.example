# ============================================================
# AgentDoc — Render Environment Variables
# Copy these into: Render Dashboard → agentdoc → Environment
#
# REQUIRED fields must be set before first deploy.
# GENERATED fields are auto-created by Render (leave blank).
# OPTIONAL fields have safe defaults.
# ============================================================

# ── Django Core ─────────────────────────────────────────────

# [GENERATED] Auto-generated by Render — do not set manually
DJANGO_SECRET_KEY=

# Must be 0 in production
DJANGO_DEBUG=0

# Your Render service hostname, e.g. agentdoc.onrender.com
DJANGO_ALLOWED_HOSTS=your-app.onrender.com

# Must match your Render URL exactly (https)
DJANGO_CORS_ALLOWED_ORIGINS=https://your-app.onrender.com

# Must match your Render URL exactly (https)
DJANGO_CSRF_TRUSTED_ORIGINS=https://your-app.onrender.com

# Required for Render reverse proxy
DJANGO_USE_X_FORWARDED_HOST=1
DJANGO_TRUST_X_FORWARDED_PROTO=1

# ── Cookies ─────────────────────────────────────────────────

DJANGO_SESSION_COOKIE_SECURE=1
DJANGO_CSRF_COOKIE_SECURE=1
DJANGO_SESSION_COOKIE_SAMESITE=Lax
DJANGO_CSRF_COOKIE_SAMESITE=Lax

# ── MongoDB ─────────────────────────────────────────────────

# [REQUIRED] MongoDB Atlas connection string
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority

MONGODB_DB_NAME=agentdoc
MONGODB_VECTOR_INDEX=documents_vector_index
MONGODB_ENABLE_VECTOR_SEARCH=1
EMBEDDING_VECTOR_DIMENSIONS=165

# ── Storage ─────────────────────────────────────────────────

# 1 = local disk (default, files reset on redeploy)
# 0 = MinIO/S3 (persistent, requires MINIO_* vars below)
USE_LOCAL_STORAGE=1

# Render persistent disk path (if using local storage)
MEDIA_ROOT=/opt/render/project/src/backend/media

# MinIO/S3 (only needed when USE_LOCAL_STORAGE=0)
# MINIO_ENDPOINT=your-minio-host:9000
# MINIO_ACCESS_KEY=your-access-key
# MINIO_SECRET_KEY=your-secret-key
# MINIO_BUCKET=documents
# MINIO_SECURE=1

# ── AI / Gemini ─────────────────────────────────────────────

# [REQUIRED] Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

GEMINI_MODEL=gemini/gemini-2.5-flash

# ── JWT Authentication ───────────────────────────────────────

JWT_ACCESS_MINUTES=60
JWT_REFRESH_DAYS=7

# ── Email Notifications (optional) ──────────────────────────

DEFAULT_FROM_EMAIL=ops@agentdoc.local

# SMTP settings (leave blank to disable email — workflow still works)
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASSWORD=your-sendgrid-api-key

# Link included in review notification emails
REVIEW_PORTAL_URL=https://your-app.onrender.com/app/#reviews

# ── Gunicorn ─────────────────────────────────────────────────

# Free tier: 2 workers max (512MB RAM)
GUNICORN_WORKERS=2
GUNICORN_TIMEOUT=120

# ── Python Runtime ───────────────────────────────────────────

PYTHON_VERSION=3.11.11
